---
interface Props {
    images: Array<string>;
}

const { images } = Astro.props;
---

<div class="slider py-5">
    <div class="slide-track">
        {
            images.map((image, i) => (
                <div class="slide">
                    <img src={image} alt={`Carousel-image-${i + 1}`} />
                </div>
            ))
        }
        {
            images.map((image, i) => (
                <div class="slide">
                    <img src={image} alt={`Carousel-image-${i + 1}`} />
                </div>
            ))
        }
    </div>
</div>

<style>
    @keyframes scroll {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(calc(-250px * 5));
        }
    }

    .slider {
        background: rgb(34, 35, 36);
        height: 100%;
        overflow: hidden;
        position: relative;
        width: 100%;
    }

    .slider::before,
    .slider::after {
        background: linear-gradient(to right, #13151a 0%, rgb(34, 35, 36) 100%);
        content: "";
        height: 100%;
        position: absolute;
        width: 100px;
        z-index: 2;
    }

    .slider::after {
        right: 0;
        top: 0;
        transform: rotateZ(180deg);
    }

    .slider::before {
        left: 0;
        top: 0;
    }

    .slide-track {
        animation: scroll 15s linear infinite;
        display: flex;
        width: calc(250px * 10);
    }

    .slide {
        display: flex;
        justify-content: center;
        height: 50px;
        width: 100%;
    }

    .slide img {
        height: 50px;
    }
</style>
