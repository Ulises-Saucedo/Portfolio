---
interface Props {
    image: string;
    imageDescription: string;
    technologies: Array<string>;
    to: string;
    title: string;
    description: string;
}

const { image, imageDescription, technologies, to, title, description } =
    Astro.props;
---

<div class="space-y-2">
    <img
        src={image}
        alt={imageDescription}
        class="w-full border-neutral-700 border rounded-lg"
    />
    <div class="flex flex-wrap gap-2">
        {
            technologies.map((item) => (
                <button
                    class="flex justify-center items-center relative bg-neutral-900 px-5 py-1 border text-left text-gray-50 text-sm border-neutral-700
                    rounded-full overflow-hidden after:absolute after:z-10 after:w-12 after:h-12 after:content[''] after:bg-sky-900 after:-left-8 after:top-8
                    after:rounded-full after:blur-lg cursor-default"
                >
                    {item}
                </button>
            ))
        }
    </div>
    <a
        href={to}
        target="_blank"
        class="text-cyan-400 underline text-lg font-bold">{title}</a
    >
    <p class="text-white text-pretty">{description}</p>
</div>
